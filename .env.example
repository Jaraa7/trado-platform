# ============================================
# TRADO Platform — Environment Variables
# ============================================

# --- AI APIs ---
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# --- Database ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# --- Redis (Upstash) ---
REDIS_URL=redis://default:password@your-upstash-url:6379

# --- Vector DB ---
QDRANT_URL=https://your-qdrant-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_key

# --- Exchanges (Testnet) ---
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_SECRET=your_binance_testnet_secret
BINANCE_TESTNET=true

BYBIT_API_KEY=your_bybit_testnet_key
BYBIT_SECRET=your_bybit_testnet_secret
BYBIT_TESTNET=true

OKX_API_KEY=your_okx_key
OKX_SECRET=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_chat_id

# --- Payments ---
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_key
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# --- App ---
APP_ENV=development
APP_SECRET_KEY=your_secret_key_change_in_production
DEBUG=true
LOG_LEVEL=INFO

# --- Risk Limits ---
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.06
MAX_MONTHLY_DRAWDOWN=0.15
MAX_LEVERAGE=3
